# ── Alchemy (RPC provider) ──────────────────────────────────────
# Sign up free at https://www.alchemy.com/
ALCHEMY_API_KEY=your_alchemy_api_key_here

# ── Deployer wallet ─────────────────────────────────────────────
# Export your private key from MetaMask → Account Details → Export
# NEVER share this or commit the real .env file!
DEPLOYER_PRIVATE_KEY=your_wallet_private_key_here

# ── Etherscan (contract verification) ──────────────────────────
# Get a free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here
